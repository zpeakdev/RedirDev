{
  "compilerOptions": {
    "target": "ESNext",
    "lib": [
      "ES2019",
      "DOM"
    ],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "types": [
      "chrome"
    ]
  },
  "include": [
    "src/**/*"
  ]
}
