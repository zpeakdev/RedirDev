{
  "name": "dnr-redirect-mv3-prototype",
  "version": "0.1.0",
  "private": true,
  "description": "MV3 + TypeScript + declarativeNetRequest 动态重定向原型",
  "type": "module",
  "scripts": {
    "build:ts": "tsc -p tsconfig.json",
    "build:assets": "node scripts/copy-assets.mjs",
    "build": "npm run build:ts && npm run build:assets",
    "dev": "npm run build:assets && tsc -p tsconfig.json --watch",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@types/chrome": "^0.0.266",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  }
}
