{
  "name": "redirdev",
  "version": "0.0.0",
  "private": true,
  "description": "动态规则实现 URL 拦截，重定向/代理到本地服务",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:watch": "vite build --watch",
    "preview": "vite preview",
    "lint": "eslint",
    "lint:error": "eslint --quiet",
    "lint:warn": "eslint --quiet=false",
    "lint:fix": "eslint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node -e \"console.log('测试');\""
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "@tailwindcss/vite": "^4.2.4",
    "antd": "^6.3.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@eslint/js": "^10.0.1",
    "@types/chrome": "^0.1.40",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10"
  }
